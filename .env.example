# Supabase — project `leadhunter-lite` (ejxproorwcwjrrlhafdf)
NEXT_PUBLIC_SUPABASE_URL=xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000

# Google OAuth (Supabase Auth provider) — from Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=xxx
GOOGLE_OAUTH_CLIENT_SECRET=xxx

# Server-side only — never exposed to the client
ANTHROPIC_API_KEY=xxx

# Stripe (sandbox keys during development)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_PRO=your_pro_price_id
STRIPE_PRICE_BUSINESS=your_business_price_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=your_stripe_pricing_table_id

# Resend (outbound email)
RESEND_API_KEY=xxx
RESEND_FROM_EMAIL=leads@leadhunterlite.com

# Twilio (outbound/inbound SMS)
TWILIO_ACCOUNT_SID=xxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=xxx

# Vercel Cron -> our own routes, shared secret to authenticate the call
CRON_SECRET=xxx
